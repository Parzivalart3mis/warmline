    "icons": "tsx scripts/icons.ts",
    "check:contrast": "tsx scripts/check-contrast.ts",
    "check:inputs": "tsx scripts/check-input-font.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,json,css,md}": [
      "prettier --write"
    ]
  },

# ── Auth (Clerk) ────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# ── Database (Neon pooled connection string) ────────────────────────
# Leave empty in local dev to use an embedded PGlite database (.pglite/).
DATABASE_URL=

# ── Sending — MUST match the Clerk account's primary email address ──
GMAIL_USER=
GMAIL_APP_PASSWORD=
# Real SMTP only sends in production. Set to 1 to enable it in dev/preview.
ENABLE_REAL_SMTP=

# ── AI ───────────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=
# block | warn — must be block in production. Debug escape hatch only.
AI_GATE_MODE=block

# ── Storage (Vercel Blob) ────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ── Rate limiting (Upstash) — optional in dev, required in prod ──────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cron (32+ random chars; Vercel sends it as a Bearer token) ───────
CRON_SECRET=

# ── E2E (optional; enables Playwright against a deployed target) ─────
E2E_BASE_URL=
E2E_CLERK_USER_EMAIL=
E2E_CLERK_USER_PASSWORD=
